# Copy to .env.local and fill in the actual values.
#
# NEXT_PUBLIC_* vars are shipped to the browser. The `anon` key is
# designed to be public — it only identifies the project; RLS policies
# decide what any caller holding it can actually read.
# (See jobwatcher repo: sql/supabase_schema.sql, docs/SUPABASE.md.)
#
# Service-role key must NEVER appear here. It lives only in the
# jobwatcher backend's .env on the Mac mini.

NEXT_PUBLIC_SUPABASE_URL=https://ydpfgiodmrhaiyiksptp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
